#!/usr/bin/env python3
"""
Teste rápido: Integração v6.1 (Ed25519) no Spine

Valida:
- Flag use_ed25519=True funciona
- Sign + Verify com Ed25519
- Backward compatibility (v6.0.3 HMAC ainda funciona)
"""

import sys
import os

# Adicionar src/ ao path
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', '..', 'src', 'core'))

from kayoscrypto_ultimate import KayosCryptoUltimate

print("="*80)
print("TESTE: Integração v6.1 (Ed25519) no Spine")
print("="*80)

# Verificar se quantum está disponível
try:
    test_cipher = KayosCryptoUltimate(use_quantum=True, use_ed25519=False)
    quantum_available = True
    print("✅ Módulo quantum disponível")
except RuntimeError:
    quantum_available = False
    print("⚠️  Módulo quantum não disponível - pulando testes de assinatura")

if quantum_available:
    # Teste 1: v6.0.3 (HMAC - backward compatibility)
    print("\n1️⃣  Teste v6.0.3 (HMAC-symmetric, default)...")
    cipher_hmac = KayosCryptoUltimate(use_quantum=True, use_ed25519=False)

    private_hmac, public_hmac = cipher_hmac.generate_keypair()
    print(f"   Private key: {private_hmac.hex()[:32]}... (32 bytes)")
    print(f"   Public key:  {public_hmac.hex()[:32]}... (32 bytes)")
    print(f"   Simétrico: {private_hmac == public_hmac}")

    message = b"KayosCrypto v6.0.3 HMAC Test"
    signature_hmac = cipher_hmac.sign_message(message, private_hmac)
    print(f"   Signature version: {signature_hmac.version} (1=HMAC)")

    is_valid_hmac = cipher_hmac.verify_signature(message, signature_hmac, public_hmac)
    print(f"   Verificação: {'✅ VÁLIDA' if is_valid_hmac else '❌ INVÁLIDA'}")

    # Teste 2: v6.1 (Ed25519 - novo!)
    print("\n2️⃣  Teste v6.1 (Ed25519-asymmetric, use_ed25519=True)...")
    cipher_ed25519 = KayosCryptoUltimate(use_quantum=True, use_ed25519=True)

    private_ed, public_ed = cipher_ed25519.generate_keypair()
    print(f"   Private key: {private_ed.hex()[:32]}... (32 bytes)")
    print(f"   Public key:  {public_ed.hex()[:32]}... (32 bytes)")
    print(f"   Assimétrico: {private_ed != public_ed}")

    message_ed = b"KayosCrypto v6.1 Ed25519 Test"
    signature_ed = cipher_ed25519.sign_message(message_ed, private_ed)
    print(f"   Signature version: {signature_ed.version} (2=Ed25519)")

    is_valid_ed = cipher_ed25519.verify_signature(message_ed, signature_ed, public_ed)
    print(f"   Verificação: {'✅ VÁLIDA' if is_valid_ed else '❌ INVÁLIDA'}")

    print("\n✅ Todos os testes de assinatura passaram!")

else:
    print("\n⚠️  Testes de assinatura pulados (módulo quantum não disponível)")
    print("   Isso é normal em ambientes sem dependências quânticas opcionais")

print("\n" + "="*80)
print("TESTE CONCLUÍDO")
print("="*80)

# Teste 3: Backward compatibility (v6.0.3 signature em sistema v6.1)
print("\n3️⃣  Teste backward compatibility...")
print("   ⚠️  Nota: v6.0.3 e v6.1 têm sistemas de assinatura diferentes")
print("   v6.0.3 (HMAC): private == public (simétrico)")
print("   v6.1 (Ed25519): private ≠ public (assimétrico)")
print("   Ambos coexistem, detecção via signature.version")

# Teste 4: Detecção de adulteração
print("\n4️⃣  Teste detecção de adulteração (v6.1)...")
fake_message = b"KayosCrypto FAKE MESSAGE"
is_valid_fake = cipher_ed25519.verify_signature(fake_message, signature_ed, public_ed)
print(f"   Mensagem adulterada: {'❌ VULNERÁVEL' if is_valid_fake else '✅ DETECTADA'}")

# Resumo
print("\n" + "="*80)
print("RESUMO")
print("="*80)
print(f"""
v6.0.3 (HMAC):
✅ Keypair gerado: {'simétrico' if private_hmac == public_hmac else 'assimétrico'}
✅ Verificação: {'OK' if is_valid_hmac else 'FALHOU'}
✅ Version: {signature_hmac.version} (1=HMAC)

v6.1 (Ed25519):
✅ Keypair gerado: {'assimétrico' if private_ed != public_ed else 'simétrico'}
✅ Verificação: {'OK' if is_valid_ed else 'FALHOU'}
✅ Version: {signature_ed.version} (2=Ed25519)
✅ Adulteração detectada: {'OK' if not is_valid_fake else 'FALHOU'}

Status Integração: {'✅ SUCESSO' if (is_valid_hmac and is_valid_ed and not is_valid_fake) else '❌ FALHOU'}
""")

print("="*80)
print("✅ Integração v6.1 (Ed25519) no Spine completa!")
print("="*80)
